{
	"name": "@seatkit/api",
	"version": "0.0.1",
	"description": "SeatKit Backend API - Fastify server with Supabase PostgreSQL",
	"type": "module",
	"license": "Apache-2.0",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "NODE_ENV=development tsx watch --env-file .env src/index.ts",
		"build": "tsup",
		"start": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"typecheck:watch": "tsc --noEmit --watch",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"test:local": "bash src/scripts/test-with-db.sh",
		"db:generate": "drizzle-kit generate",
		"db:baseline": "tsx src/scripts/baseline.ts",
		"db:migrate": "tsx --env-file .env src/scripts/migrate.ts",
		"db:migrate:test": "tsx src/scripts/migrate-test.ts",
		"db:seed": "tsx src/scripts/seed.ts",
		"db:studio": "drizzle-kit studio",
		"secrets:setup": "tsx src/scripts/setup-simple-secrets.ts"
	},
	"dependencies": {
		"@fastify/cors": "^10.0.1",
		"@fastify/env": "^5.0.1",
		"@fastify/helmet": "^12.0.1",
		"@fastify/multipart": "10.0.0",
		"@fastify/rate-limit": "^10.1.1",
		"@fastify/sensible": "^6.0.3",
		"@fastify/swagger": "^9.7.0",
		"@fastify/websocket": "^11.0.1",
		"@google-cloud/secret-manager": "^5.0.1",
		"@scalar/fastify-api-reference": "^1.51.0",
		"@seatkit/engine": "workspace:*",
		"@seatkit/types": "workspace:*",
		"@seatkit/utils": "workspace:*",
		"@supabase/supabase-js": "2.102.1",
		"better-auth": "^1.6.0",
		"better-auth-invite-plugin": "^0.4.1",
		"drizzle-orm": "^0.41.0",
		"fastify": "^5.1.0",
		"fastify-better-auth": "^1.2.0",
		"fastify-plugin": "^5.1.0",
		"fastify-type-provider-zod": "^6.1.0",
		"nodemailer": "^8.0.5",
		"pg-listen": "^1.7.0",
		"postgres": "^3.4.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22.8.7",
		"@types/nodemailer": "^8.0.0",
		"@types/ws": "^8.18.1",
		"drizzle-kit": "^0.31.10",
		"pino-pretty": "12.1.0",
		"tsup": "^8.3.5",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3",
		"vitest": "^2.1.4"
	}
}